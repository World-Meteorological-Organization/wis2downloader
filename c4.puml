@startuml C4_Container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container Diagram for WIS2 Downloader System

Person(user, "User", "A user interacting with the system.")

System_Boundary(core_system, "WIS2 Downloader System") {

    Container(frontend_app, "Frontend Web Application", "Web Browser (HTML, CSS, JavaScript)", "Provides a user interface to search WIS2 Global Catalogues and manage subscriptions via the API.")
    Container(subscription_manager, "Subscription Manager", "Python (Flask)", "Manages subscriptions, exposes API, and provides a web UI for configuration. Exposes Prometheus metrics.")
    Container(celery_worker, "Celery Worker", "Python (Celery)", "Asynchronously downloads data based on subscriptions. Writes Prometheus metrics to shared volume.")
    Container(redis, "Redis", "Data Store", "Message broker for Celery tasks, stores task results, and used for distributed locks/tracking.")

    Container(prometheus, "Prometheus", "Monitoring System (Go)", "Collects metrics from the Subscription Manager and Celery workers.")
    Container(loki, "Loki", "Log Aggregation System (Go)", "Collects logs from all Docker containers.")
    Container(grafana, "Grafana", "Monitoring Dashboard (Go/React)", "Visualizes metrics from Prometheus and logs from Loki.")

}

System(external_wis2_catalogue, "External WIS2 Global Catalogue", "API (HTTP/S)", "External system providing WIS2 catalogue metadata.")
System(external_data_source, "External Data Source", "Internet (HTTP/S)", "Source of data files to be downloaded.")

Rel(user, frontend_app, "Uses", "HTTP/S")

Rel(frontend_app, subscription_manager, "Sends commands to", "HTTP/S API")
Rel(frontend_app, external_wis2_catalogue, "Searches and retrieves metadata from", "HTTP/S API")
Rel(frontend_app, loki, "Sends logs to", "Docker Logging Driver")


Rel(subscription_manager, celery_worker, "Dispatches tasks to", "Redis (Celery)")
Rel(subscription_manager, redis, "Stores/Retrieves configuration and dispatches tasks", "Redis")
Rel(subscription_manager, prometheus, "Exposes metrics to", "HTTP /metrics endpoint")
Rel(subscription_manager, loki, "Sends logs to", "Docker Logging Driver")

Rel(celery_worker, redis, "Retrieves tasks and stores results", "Redis")
Rel(celery_worker, external_data_source, "Downloads data from", "HTTP/S")
Rel(celery_worker, subscription_manager, "Writes Prometheus metrics to shared volume for", "Filesystem Mount")
Rel(celery_worker, loki, "Sends logs to", "Docker Logging Driver")

Rel(prometheus, subscription_manager, "Scrapes metrics from", "HTTP /metrics endpoint")

Rel(grafana, prometheus, "Queries metrics from", "Prometheus API")
Rel(grafana, loki, "Queries logs from", "Loki API")

@enduml