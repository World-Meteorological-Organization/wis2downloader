#  Secrets (updated by setup.sh)  #
#/ ============================= /#
FLASK_SECRET_KEY="default"
REDIS_PASSWORD="default"
GF_SECURITY_ADMIN_PASSWORD="default"

#  Deployment settings  #
#/ =================== /#
LOG_LEVEL=INFO
FLASK_DEBUG=false
HOST_DATA_PATH=./downloads
DOWNLOAD_RETENTION_PERIOD=30

#  Shared between multiple containers  #
#/ ================================== /#
CONTAINER_DATA_PATH=/data
# Redis
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TTL_SECONDS=3600
REDIS_MESSAGE_LOCK=300
# CELERY
CELERY_BACKEND_DB=0
CELERY_RESULT_DB=1
SCHEDULER_BACKEND_DB=2
SCHEDULER_RESULT_DB=3
# Grafana
GF_SECURITY_ADMIN_USER="admin"
